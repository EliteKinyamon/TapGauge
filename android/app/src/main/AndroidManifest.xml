<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Microphone is the ONLY runtime-sensitive permission. Requested at
         runtime with a rationale screen (spec section 3.1 / 8). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Declares the mic feature but does not require it, so the app still
         installs on the rare device without one (it just can't measure). -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />

    <!-- NO INTERNET / ACCESS_NETWORK_STATE permission by design. Everything is
         on-device (spec section 8, section 11, section 12). -->

    <application
        android:name=".TapGaugeApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TapGauge"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TapGauge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
